{% extends 'base.html.twig' %}

{% block page_title %}
    <h1 class="text-center">{{ "company.review_for"|trans }} {{ companyName }}</h1>
{% endblock %}

{% block body %}

<div class="example-wrapper">
    <h1>Review List</h1>

    <table class="table table-striped">
        <thead>
            <tr>
                <th scope="col">{{ "common.rating"|trans }}</th>
                <th scope="col">{{ "common.review"|trans }}</th>
                <th scope="col">{{ "common.created_at"|trans }}</th>
                <th scope="col">{{ "common.actions"|trans }}</th>
            </tr>
        </thead>
        <tbody>
            {% for review in reviews %}
                <tr>
                    <td>{{ component('Rating', {rating: review.rating}) }}</td>
                    <td><span class="review-table-span">{{ review.reviewText }}</span></td>
                    <td>{{ review.createdAt|date('Y-m-d') }}</td>
                    <td>
                        <a href="/review/{{ review.id }}/show" class="btn btn-primary">
                            {{ "common.show"|trans }}
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
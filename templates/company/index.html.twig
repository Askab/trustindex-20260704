{% extends 'base.html.twig' %}

{% block page_title %}
    <h1 class="text-center">Company statistics</h1>
{% endblock %}

{% block body %}

    <div class="container">
        <div class="row">
            <div class="col-12">
                <table class="table table-striped">
                    <tr>
                        <th scope="col">{{ "common.company"|trans }}</th>
                        <th scope="col">{{ "common.rating"|trans }}</th>
                        <th scope="col">{{ "common.number_of_reviews"|trans }}</th>
                        <th scope="col">{{ "common.actions"|trans }}</th>
                    </tr>
                    {% for company in companies %}
                        <tr>
                            <td>{{ company.company_name }}</td>
                            <td>{{ component('Rating', {rating: company.average}) }}</td>
                            <td>{{ company.count }}</td>
                            <td>
                                <a href="/companies/{{ company.company_name }}/show" class="btn btn-primary">{{ "common.show"|trans }}</a>
                            </td>
                        </tr>
                    {% endfor %}
                </table>
            </div>
        </div>
    </div>

{% endblock %}

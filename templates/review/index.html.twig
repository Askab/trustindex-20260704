{% extends 'base.html.twig' %}

{% block page_title %}
    <h1 class="text-center">{{ "review_form.write_a_review"|trans }}!</h1>
{% endblock %}

{% block body %}

    {% for message in app.flashes('error') %}
        <div class="flash-error">
            {{ message }}
        </div>
    {% endfor %}

    <div class="container">
        <div class="row">
            <div class="col-12">
                <h1>Review</h1>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                {{ form_start(form) }}

                    {{ form_widget(form) }}

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                            <i class="bi bi-send-fill me-2"></i>{{ "review_form.submit_review"|trans }}
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}